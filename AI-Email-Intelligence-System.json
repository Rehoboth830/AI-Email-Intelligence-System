    {
      "parameters": {
        "jsCode": "// Step 1: Safely extract JSON from AI output (handles markdown wrapping)\nlet raw = ($json.output || '').toString().trim();\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\nif (!match) {\n  throw new Error('AI did not return valid JSON. Raw output: ' + raw.substring(0, 200));\n}\nlet aiOutput;\ntry {\n  aiOutput = JSON.parse(match[0]);\n} catch (e) {\n  throw new Error('Failed to parse AI JSON: ' + e.message);\n}\n\n// Step 2: Convert action items array to readable bullet text\nif (Array.isArray(aiOutput.action_items) && aiOutput.action_items.length > 0) {\n  aiOutput.action_items = '• ' + aiOutput.action_items.join('\\n• ');\n} else {\n  aiOutput.action_items = '';\n}\n\n// Step 3: Resolve relative meeting dates to ISO format\nif (aiOutput.meeting_date) {\n  const today = new Date();\n  const value = aiOutput.meeting_date.trim().toLowerCase();\n  let meetingDate = null;\n  if (value === 'today') {\n    meetingDate = new Date(today);\n  } else if (value === 'tomorrow') {\n    meetingDate = new Date(today);\n    meetingDate.setDate(today.getDate() + 1);\n  } else {\n    const parsed = new Date(aiOutput.meeting_date);\n    if (!isNaN(parsed.getTime())) {\n      meetingDate = parsed;\n    }\n  }\n  aiOutput.meeting_date = meetingDate\n    ? meetingDate.toISOString().split('T')[0]\n    : null;\n}\n\n// Step 4: Null guards — rich_text fields must never be null\naiOutput.meeting_time = aiOutput.meeting_time || '';\naiOutput.summary = aiOutput.summary || '';\n\n// Step 5: Select fields must never be null\naiOutput.priority = aiOutput.priority || 'Low';\naiOutput.category = aiOutput.category || 'Other';\n\n// Step 6: Boolean fields must always be boolean\naiOutput.important = typeof aiOutput.important === 'boolean' ? aiOutput.important : false;\naiOutput.has_meeting = typeof aiOutput.has_meeting === 'boolean' ? aiOutput.has_meeting : false;\n\nconst rawScore = aiOutput.confidence_score;\nconst parsedScore = parseInt(rawScore, 10);\naiOutput.confidence_score = !isNaN(parsedScore)\n  ? Math.min(100, Math.max(0, parsedScore))\n  : 0;\naiOutput.low_confidence = aiOutput.confidence_score < 70;\n\n// Step 8: Validate required AI output\nconst validationErrors = [];\nif (!aiOutput.summary.trim()) {\n  validationErrors.push('Summary is missing');\n}\nif (!aiOutput.priority) {\n  validationErrors.push('Priority is missing');\n}\nif (!aiOutput.category) {\n  validationErrors.push('Category is missing');\n}\n\n// Add validation status to output\naiOutput.isValid = validationErrors.length === 0;\naiOutput.validationErrors = validationErrors.join(', ');\n\n// Return the enriched AI output\nreturn [{ json: aiOutput }];"
      },
